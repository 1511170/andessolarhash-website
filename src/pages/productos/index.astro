---
import Layout from '../../layouts/Layout.astro';

/** Diseño alineado a Figma ANDES SOLAR HASH — PRODUCTOS (nodo 72:137) */

const imgHero = '/images/productos/figma/hero_portada.webp';
const imgMinerCard = '/images/productos/figma/producto_s21_card.webp';
const imgHosting = '/images/productos/figma/hosting_promo.webp';
const imgNft = '/images/productos/figma/nft_robot.webp';
const imgNewsletter = '/images/productos/figma/newsletter_plane.webp';

const s21Series = [
  {
    id: 's21-xp',
    tag: 'MÁXIMA EFICIENCIA',
    title: 'Antminer S21 XP',
    hashRate: '270 TH/s',
    efficiency: '13.5 J/TH',
    roi: '17–24 Meses',
    price: '$7.999.999',
    clpMuted: false,
    image: '/images/products/antminer-s21-xp.png',
  },
  {
    id: 's21-pro',
    tag: 'BALANCE Y POTENCIA',
    title: 'Antminer S21 Pro',
    hashRate: '234 TH/s',
    efficiency: '15.0 J/TH',
    roi: '18–25 Meses',
    price: '$5.499.999',
    clpMuted: true,
    image: '/images/products/antminer-s21-pro.png',
  },
  {
    id: 's21-plus',
    tag: 'ALTA CAPACIDAD',
    title: 'Antminer S21 +',
    hashRate: '216 TH/s',
    efficiency: '16.5 J/TH',
    roi: '18–26 Meses',
    price: '$4.999.999',
    clpMuted: false,
    image: '/images/products/antminer-s21-plus.png',
  },
];

const l9Series = [
  {
    id: 'l9-17000',
    tag: 'ROI MÁS RÁPIDO',
    title: 'Antminer L9 17000',
    hashRate: '17.000 MH/s',
    roi: '13–21 Meses',
    crypto: 'LTC + DOGE',
    price: '$8.600.000',
    image: '/images/products/antminer-l9-17000.png',
  },
  {
    id: 'l9-16000',
    tag: 'ALTA CAPACIDAD',
    title: 'Antminer L9 16000',
    hashRate: '16.000 MH/s',
    roi: '14–21 Meses',
    crypto: 'LTC + DOGE',
    price: '$8.200.000',
    image: '/images/products/antminer-l9-16000.png',
  },
  {
    id: 'l9-15000',
    tag: 'ALTA CAPACIDAD',
    title: 'Antminer L9 15000',
    hashRate: '15.000 MH/s',
    roi: '18–26 Meses',
    crypto: 'LTC + DOGE',
    price: '$7.700.000',
    image: '/images/products/antminer-l9-15000.png',
  },
];

const faqMain = [
  {
    q: '¿Qué significa ROI y cuánto tiempo tarda?',
    a: 'El ROI (Retorno de la Inversión) es el tiempo que toma recuperar el costo inicial del equipo con el Bitcoin que minas. Nuestros equipos más eficientes tienen un ROI estimado de 13 a 26 meses.',
  },
  {
    q: '¿Por qué es tan importante la eficiencia (J/TH)?',
    a: 'A menor J/TH, menos electricidad pagas por cada Bitcoin acumulado. Con tarifas competitivas, la eficiencia del ASIC es el principal motor de margen a largo plazo.',
  },
  {
    q: '¿Qué garantía tengo sobre el equipo?',
    a: 'Garantía de 12 meses por defectos de fabricación y soporte técnico local en Chile. Detalle de cobertura en cada cotización y ficha de producto.',
  },
];

const glossary = [
  { q: 'J/TH (Julios por Terahash)', a: 'Mide cuánta energía consume el minero por cada unidad de hashrate. Valores más bajos implican mayor eficiencia.' },
  { q: 'Hashrate (TH/s o MH/s)', a: 'Potencia de procesamiento del minero. En Bitcoin se usa TH/s; en Scrypt (LTC/DOGE) suele expresarse en MH/s.' },
  { q: 'Smart Contract y MetaMask', a: 'Para fraccionamiento y NFTs productivos utilizamos contratos verificables; MetaMask es la wallet estándar para recibir participaciones.' },
];
---

<Layout title="Productos | Andes Solar Hash - Mineros ASIC Bitcoin y Dogecoin">
  <!-- HERO — Figma Header 72:138 -->
  <section
    class="relative min-h-[min(100svh,620px)] flex flex-col justify-end border-b border-white/10 overflow-hidden pt-28"
    style="background: var(--bg-deep);"
  >
    <div class="absolute inset-0 pointer-events-none min-h-full">
      <img
        src={imgHero}
        alt=""
        class="absolute inset-0 w-full h-full min-h-full min-w-full object-cover object-center scale-105 opacity-45 md:opacity-[0.56]"
        loading="eager"
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-[#181c38]/95 from-[22%] via-[#0b0d1b]/70 to-[#0b0d1b]/88"
      />
    </div>

    <div class="relative z-10 w-full max-w-[1280px] mx-auto px-6 md:px-8 pb-16 md:pb-24 text-center">
      <p class="font-archivo font-bold text-sm text-white tracking-[0.14em] uppercase mb-3">
        Catálogo oficial de infraestructura ASH
      </p>
      <h1
        class="font-maven font-black text-3xl sm:text-4xl md:text-5xl lg:text-[3.35rem] leading-tight mb-5"
        style="background: linear-gradient(to right, #e08324, #f7ad1f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        Inversión Principal: Mineros de Alta<br class="hidden sm:block" /> Eficiencia (BTC).
      </h1>
      <p class="font-archivo text-lg md:text-xl text-white max-w-3xl mx-auto leading-relaxed mb-8">
        Seleccionamos mineros ASIC por su eficiencia energética (J/TH), garantizando el máximo margen de
        acumulación y un ROI real de 13–26 meses.
      </p>
      <a
        href="#serie-s21"
        class="inline-flex items-center justify-center gap-2 border border-[#f7ad1f] rounded px-5 py-3.5 font-maven font-bold text-base text-white hover:bg-[#f7ad1f]/10 transition-colors max-w-full"
      >
        <svg class="w-5 h-5 shrink-0 text-[#f7ad1f]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 6v6l4 2" stroke-linecap="round" />
        </svg>
        <span class="text-center leading-snug">VER FICHA TÉCNICA Y PRECIOS</span>
      </a>
    </div>
  </section>

  <!-- SERIE S21 -->
  <section id="serie-s21" class="py-16 md:py-20 px-4 md:px-8 lg:px-12" style="background: var(--bg-deep);">
    <div class="max-w-[1280px] mx-auto">
      <div class="text-center mb-10 md:mb-12">
        <h2 class="font-maven font-bold text-2xl md:text-[30px] text-white mb-4">
          Serie Antminer S21: El Mejor Margen de la Industria
        </h2>
        <p class="font-archivo text-base md:text-lg text-white max-w-3xl mx-auto">
          La eficiencia del hardware, combinada con nuestro costo eléctrico de $0.088 USD/kWh, determina la
          rentabilidad de su inversión.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 justify-center">
        {s21Series.map((p) => (
          <article
            class="flex flex-col border-t-4 border-[#f7ad1f] rounded-xl pt-7 px-6 pb-6 bg-transparent max-w-md mx-auto w-full"
            style="box-shadow: 0 0 0 1px rgba(255,255,255,0.06);"
          >
            <div class="flex items-center justify-between mb-3">
              <span class="font-archivo font-bold text-xs text-[#f7ad1f] tracking-wide">{p.tag}</span>
              <svg class="w-6 h-6 text-[#f7ad1f]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z" />
              </svg>
            </div>
            <div class="w-full aspect-square max-h-[280px] mb-3 flex items-center justify-center">
              <img src={p.image} alt={p.title} class="max-h-full w-full object-contain" loading="lazy" />
            </div>
            <h3 class="font-maven font-black text-2xl md:text-[30px] text-white mb-4">{p.title}</h3>
            <dl class="space-y-2 text-sm border-t border-white/0">
              <div class="border-b border-white pb-1">
                <dt class="font-archivo text-[#d1d5db] text-sm">Poder (Hashrate):</dt>
                <dd class="font-mono font-bold text-lg text-white pt-1">{p.hashRate}</dd>
              </div>
              <div class="border-b border-white pb-1">
                <dt class="font-archivo text-[#d1d5db] text-sm">Consumo (Eficiencia):</dt>
                <dd class="font-mono font-bold text-lg text-[#f7ad1f] pt-1">{p.efficiency}</dd>
              </div>
              <div class="border-b border-white pb-1">
                <dt class="font-archivo text-[#d1d5db] text-sm">ROI Estimado (con Hosting ASH):</dt>
                <dd class="font-mono font-bold text-lg text-[#d1d5db] pt-1">{p.roi}</dd>
              </div>
            </dl>
            <div class="flex items-end justify-center gap-1 pt-4 mb-4">
              <span class="font-archivo font-black text-3xl text-white">{p.price}</span>
              <span
                class:list={['font-archivo text-lg', p.clpMuted ? 'text-[#aeaf9c]' : 'text-white']}
              >
                CLP
              </span>
            </div>
            <a
              href={`/productos/${p.id}/`}
              class="mt-auto block w-full text-center bg-[#f7ad1f] text-black font-archivo font-bold text-lg py-4 rounded hover:opacity-95 transition-opacity"
            >
              COMPRAR CON WEBPAY
            </a>
          </article>
        ))}
      </div>
      <p class="text-center text-sm text-[#6b7280] font-archivo mt-10 max-w-4xl mx-auto">
        *Nota: Todos los precios son para la venta del equipo en Chile y no incluyen el contrato de hosting anual.
      </p>
    </div>
  </section>

  <!-- SERIE L9 — fondo #15172e Figma -->
  <section id="serie-l9" class="py-16 md:py-20 px-4 md:px-8 lg:px-12 bg-[#15172e]">
    <div class="max-w-[1280px] mx-auto">
      <div class="text-center mb-10 md:mb-12">
        <h2 class="font-maven font-bold text-2xl md:text-[30px] text-white mb-4">
          Diversificación: Retorno Más Rápido (LTC + DOGE)
        </h2>
        <p class="font-archivo text-base md:text-lg text-white max-w-3xl mx-auto">
          Los Antminer L9 ofrecen la opción de un ROI acelerado (hasta 13 meses), ideal para perfiles que buscan
          diversificar la producción de activos.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
        {l9Series.map((p) => (
          <article
            class="flex flex-col border-t-4 border-[#f7ad1f] rounded-xl pt-6 px-6 pb-6 max-w-md mx-auto w-full"
            style="background: transparent; box-shadow: 0 0 0 1px rgba(255,255,255,0.08);"
          >
            <div class="flex items-center justify-between mb-3">
              <span class="font-archivo font-bold text-xs text-[#f7ad1f]">{p.tag}</span>
              <svg class="w-6 h-6 text-[#f7ad1f]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
              </svg>
            </div>
            <div class="w-full aspect-square max-h-[280px] mb-3 flex items-center justify-center">
              <img src={p.image} alt={p.title} class="max-h-full w-full object-contain" loading="lazy" />
            </div>
            <h3 class="font-maven font-black text-2xl md:text-[30px] text-white mb-4">{p.title}</h3>
            <dl class="space-y-2 flex-grow">
              <div class="border-b border-white/15 pb-1">
                <dt class="font-archivo text-[#d1d5db] text-sm">Hashrate:</dt>
                <dd class="font-mono font-bold text-lg text-white pt-1">{p.hashRate}</dd>
              </div>
              <div class="border-b border-white/15 pb-1">
                <dt class="font-archivo text-[#d1d5db] text-sm">ROI Estimado (con Hosting ASH):</dt>
                <dd class="font-mono font-bold text-lg text-[#d1d5db] pt-1">{p.roi}</dd>
              </div>
              <div class="border-b border-white/15 pb-1">
                <dt class="font-archivo text-[#d1d5db] text-sm">Criptomoneda:</dt>
                <dd class="font-mono font-bold text-lg text-white pt-1">{p.crypto}</dd>
              </div>
            </dl>
            <div class="flex items-end justify-center gap-1 pt-4 mb-4">
              <span class="font-archivo font-black text-3xl text-white">{p.price}</span>
              <span class="font-archivo text-lg text-[#f7ad1f]">CLP</span>
            </div>
            <a
              href={`/productos/${p.id}/`}
              class="mt-auto block w-full text-center bg-[#f7ad1f] text-black font-archivo font-bold text-lg py-4 rounded hover:opacity-95 transition-opacity"
            >
              COMPRAR CON WEBPAY
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ — layout dos columnas Figma -->
  <section id="faq" class="py-16 md:py-24 px-4 md:px-8 lg:px-12" style="background: var(--bg-deep);">
    <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-5">
        <h2 class="font-maven font-black text-2xl md:text-[30px] text-white uppercase leading-tight mb-6">
          Preguntas Frecuentes<br />y Definiciones Clave
        </h2>
        <p class="font-archivo text-sm md:text-base text-white leading-relaxed">
          Conocé los términos, métricas y criterios fundamentales que impactan en la eficiencia, el retorno y la toma
          de decisiones dentro del ecosistema minero.
        </p>
      </div>
      <div class="lg:col-span-7 space-y-10">
        <div>
          <h3 class="font-maven font-bold text-lg text-[#f7ad1f] uppercase tracking-wide mb-4">
            Aspectos Clave del Negocio
          </h3>
          <div class="space-y-0">
            {faqMain.map((item, i) => (
              <div class="faq-item border-b border-white/20" data-faq-index={i}>
                <button
                  type="button"
                  class="faq-trigger w-full flex items-start justify-between gap-4 py-4 text-left group"
                  data-faq-btn
                >
                  <span class="font-maven font-bold text-base md:text-lg text-white pr-2">{item.q}</span>
                  <span class="faq-icon text-sky-400 text-xl font-light leading-none shrink-0 w-6 text-center transition-transform">+</span>
                </button>
                <div class="faq-panel hidden pb-4">
                  <p class="font-archivo text-sm text-white leading-relaxed">{item.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-maven font-bold text-lg text-[#f7ad1f] uppercase tracking-wide mb-4">
            Glosario para Inversores Nuevos
          </h3>
          <div class="space-y-0">
            {glossary.map((item, i) => (
              <div class="faq-item border-b border-white/20" data-glossary-index={i}>
                <button
                  type="button"
                  class="faq-trigger w-full flex items-start justify-between gap-4 py-3 text-left"
                  data-faq-btn
                >
                  <span class="font-maven font-bold text-base text-white">{item.q}</span>
                  <span class="faq-icon text-sky-400 text-xl font-light leading-none shrink-0 w-6 text-center transition-transform">+</span>
                </button>
                <div class="faq-panel hidden pb-4">
                  <p class="font-archivo text-sm text-white/90">{item.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hosting + NFT -->
  <section class="py-16 md:py-20 px-4 md:px-8 lg:px-12 bg-[#15172e]">
    <div class="max-w-[1280px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">
      <article
        class="relative rounded-xl border border-[#f7ad1f]/40 border-l-4 border-l-[#f7ad1f] bg-[#1a1d3a] p-8 md:p-9 flex flex-col gap-4 overflow-hidden"
      >
        <div class="flex items-center gap-2 text-[#f7ad1f]">
          <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" />
            <line x1="4" y1="22" x2="4" y2="15" />
          </svg>
          <h3 class="font-maven font-extrabold text-xl md:text-2xl text-[#f7ad1f]">
            Hosting: El Componente de Costo
          </h3>
        </div>
        <p class="font-archivo text-base text-white leading-relaxed flex-grow">
          La clave del margen es el costo operativo. Aloje su minero con nuestra tarifa de
          <strong class="text-white"> $0.088 USD/kWh</strong> en granjas con energía 100% renovable. Incluye
          monitoreo 24/7 y mantenimiento.
        </p>
        <a
          href="/hosting/"
          class="inline-flex self-start bg-[#f7ad1f] text-[#0b0d1b] font-maven font-bold text-base px-6 py-3 rounded hover:opacity-95 transition-opacity"
        >
          COTIZAR HOSTING Y TARIFA
        </a>
        <div class="mt-4 flex justify-center lg:justify-end pointer-events-none select-none">
          <img src={imgHosting} alt="" class="max-h-44 w-auto object-contain opacity-95" loading="lazy" />
        </div>
      </article>

      <article
        class="relative rounded-xl border border-[#f7ad1f]/40 border-l-4 border-l-[#f7ad1f] bg-[#1a1d3a] p-8 md:p-9 flex flex-col gap-4 overflow-hidden"
      >
        <div class="flex items-center gap-2 text-[#f7ad1f]">
          <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <path d="M3 9h18M9 21V9" />
          </svg>
          <h3 class="font-maven font-extrabold text-xl md:text-2xl text-[#f7ad1f]">
            NFTs productivos: Inversión Accesible
          </h3>
        </div>
        <p class="font-archivo text-base text-white leading-relaxed flex-grow">
          Participe en la minería sin comprar el equipo completo. Los tokens mineros (desde 1% de hashrate) se
          distribuyen automáticamente a su wallet MetaMask.
        </p>
        <a
          href="/nft/"
          class="inline-flex self-start bg-[#f7ad1f] text-[#0b0d1b] font-maven font-bold text-base px-6 py-3 rounded hover:opacity-95 transition-opacity"
        >
          VER PLANES DE FRACCIONAMIENTO
        </a>
        <div class="mt-4 flex justify-center lg:justify-end pointer-events-none select-none">
          <img src={imgNft} alt="" class="max-h-52 w-auto object-contain" loading="lazy" />
        </div>
      </article>
    </div>
  </section>

  <!-- Newsletter — Figma 92:20 -->
  <section class="relative py-16 md:py-20 overflow-hidden" style="background: #0b0d1b;">
    <div class="absolute right-0 top-0 bottom-0 w-full max-w-md opacity-90 mix-blend-lighten pointer-events-none hidden md:block">
      <img src={imgNewsletter} alt="" class="h-full w-full object-cover object-right" loading="lazy" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0b0d1b] from-[55%] to-transparent pointer-events-none" />
    <div class="relative z-10 max-w-xl mx-auto text-center px-6 md:px-8">
      <h2
        class="font-maven font-black text-2xl md:text-[30px] uppercase mb-4"
        style="background: linear-gradient(to right, #e08324, #f7ad1f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        Reciba la Tesis de Inversión ASH.
      </h2>
      <p class="font-archivo text-lg text-white mb-8">
        Únase a nuestro newsletter exclusivo. Reciba análisis cíclicos y noticias de infraestructura que realmente
        mueven la aguja.
      </p>
      <form
        class="flex flex-col sm:flex-row gap-3 justify-center items-stretch max-w-md mx-auto"
        onsubmit="event.preventDefault(); alert('¡Gracias por suscribirte!');"
      >
        <input
          type="email"
          required
          placeholder="Su correo electrónico aquí..."
          class="flex-1 rounded px-4 py-3.5 font-archivo text-base bg-white/10 border border-white/20 text-white placeholder:text-[#6b7280] outline-none focus:border-[#f7ad1f]/50"
        />
        <button
          type="submit"
          class="rounded-full px-8 py-3.5 font-maven font-bold text-[#1d2242] bg-[#f7ad1f] hover:opacity-95 transition-opacity whitespace-nowrap"
        >
          SUSCRIBIRME
        </button>
      </form>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('[data-faq-btn]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('.faq-item');
        if (!item) return;
        var panel = item.querySelector('.faq-panel');
        var icon = item.querySelector('.faq-icon');
        var open = panel && !panel.classList.contains('hidden');
        document.querySelectorAll('.faq-panel').forEach(function (p) {
          p.classList.add('hidden');
        });
        document.querySelectorAll('.faq-icon').forEach(function (ic) {
          ic.textContent = '+';
          ic.classList.remove('rotate-45');
        });
        if (!open && panel && icon) {
          panel.classList.remove('hidden');
          icon.textContent = '−';
        }
      });
    });
  </script>

  <style>
    .rotate-45 {
      transform: rotate(45deg);
    }
    .faq-item .faq-trigger:hover .faq-icon {
      opacity: 0.85;
    }
  </style>
</Layout>
