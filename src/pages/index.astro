  <script>
    // Actualizar precio BTC cada 30 segundos
    async function updateBTCPrice() {
      try {
        const response = await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd&include_24hr_change=true');
        const data = await response.json();
        const btc = data.bitcoin;
        
        const priceEl = document.getElementById('btc-price');
        if (priceEl && btc.usd) {
          priceEl.textContent = '$' + btc.usd.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
      } catch (e) {
        console.log('Error fetching BTC price:', e);
      }
    }
    
    // Actualizar al cargar y cada 30 segundos
    updateBTCPrice();
    setInterval(updateBTCPrice, 30000);
  </script>
