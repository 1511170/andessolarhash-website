---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import FeaturedProduct from '../components/FeaturedProduct.astro';
import { getCollection } from 'astro:content';

const newsGradients = [
  'linear-gradient(135deg,#1a2040,#2a3060)',
  'linear-gradient(135deg,#1a2a40,#204050)',
  'linear-gradient(135deg,#1a1a35,#252540)',
];

const blogPosts = await getCollection('blog', ({ data }) => data.published !== false);
const sortedBlog = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const newsDateFmt = new Intl.DateTimeFormat('es', { day: 'numeric', month: 'short', year: 'numeric' });
const newsItems = sortedBlog.slice(0, 6).map((post, i) => ({
  href: `/blog/${post.slug}/`,
  date: newsDateFmt.format(post.data.date).replace(/\./g, '').toUpperCase(),
  category: post.data.category.toUpperCase(),
  title: post.data.title,
  image: post.data.image,
  gradient: newsGradients[i % newsGradients.length],
}));

const products = [
  {
    title: 'Venta de\nMineros ASIC',
    tag: 'PÚBLICO: Inversor Decidido / Conversión Rápida',
    description: 'Adquiere equipos de minería Bitcoin de alto rendimiento, seleccionados por eficiencia energética y compatibilidad con nuestra infraestructura.',
    image: '/images/home/productos/producto_minero_asic.png',
    features: [
      'Equipos nuevos y verificados (S21 / S21 XP)',
      'Compatibles con energía de bajo costo ($0.088/kWh)',
      'Entrega y soporte local en Chile',
      'Opción de hosting o retiro del equipo'
    ],
    cta: { text: 'COMPRAR EQUIPO AHORA', href: '/productos/', style: 'white' }
  },
  {
    title: 'Hosting Minero\nProfesional',
    tag: 'PÚBLICO: Operadores / Tickets Altos / Contratos',
    description: 'Aloja tu equipo ASIC en infraestructura optimizada para minería de Bitcoin, con energía de bajo costo, monitoreo continuo y soporte técnico local.',
    image: '/images/home/productos/producto_hosting_profesional.png',
    features: [
      'Energía eléctrica optimizada ($0.088/kWh competitivo)',
      'Monitoreo técnico continuo y trazable',
      'Mantenimiento y soporte local en Chile',
      'Contratos claros y trazables'
    ],
    cta: { text: 'CONTÁCTANOS', href: '/contacto/#contacto', style: 'gold', note: 'Agendar llamada de evaluación' }
  },
  {
    title: 'NFTs Productivos\nde Minería Bitcoin',
    tag: 'PÚBLICO: Inversor digital / Web3 / Acceso simplificado',
    description: 'Accede a minería real de Bitcoin mediante NFTs respaldados por infraestructura operativa, sin comprar equipos ni gestionar operación técnica.',
    image: '/images/home/productos/producto_nft_productivos.png',
    features: [
      'NFTs vinculados a hashrate real en operación',
      'Infraestructura minera operada por Andes Solar Hash',
      'Energía competitiva de diferentes países integrada',
      'Participación desde montos accesibles (desde USD 60)'
    ],
    cta: { text: 'VER NFT', href: '/nft/', style: 'orange', note: 'Explorá los NFTs disponibles' }
  }
];

/** @see https://www.youtube.com/@andessolarhash — lista “Subidas”: id = UC… → UU… (siempre el último upload primero) */
const YOUTUBE_CHANNEL_ID = 'UC0borrHdw54_FczEkRc7CeQ';
const YOUTUBE_CHANNEL_URL = 'https://www.youtube.com/@andessolarhash';
const youtubeUploadsPlaylistId = YOUTUBE_CHANNEL_ID.replace(/^UC/, 'UU');
const youtubeEmbedSrc = `https://www.youtube-nocookie.com/embed/videoseries?list=${youtubeUploadsPlaylistId}`;

const youtubeLatestDefaults = {
  title: 'Último video en YouTube',
  description:
    'En nuestro canal explicamos cómo la minería industrial opera en ciclos, con foco en acumulación y contexto del mercado.',
  watchUrl: YOUTUBE_CHANNEL_URL,
};

let youtubeLatest = { ...youtubeLatestDefaults };
try {
  const feedRes = await fetch(
    `https://www.youtube.com/feeds/videos.xml?channel_id=${YOUTUBE_CHANNEL_ID}`,
    { headers: { 'User-Agent': 'AndesSolarHashSite/1.0' } }
  );
  if (feedRes.ok) {
    const xml = await feedRes.text();
    const entryXml = xml.match(/<entry>([\s\S]*?)<\/entry>/)?.[1];
    if (entryXml) {
      const videoId = entryXml.match(/<yt:videoId>([^<]+)<\/yt:videoId>/)?.[1];
      const rawTitle = entryXml.match(/<title>([^<]*)<\/title>/)?.[1];
      const mediaDesc = entryXml.match(
        /<media:description[^>]*>([\s\S]*?)<\/media:description>/
      )?.[1];
      if (videoId) {
        youtubeLatest.watchUrl = `https://www.youtube.com/watch?v=${videoId}`;
      }
      if (rawTitle) {
        youtubeLatest.title = rawTitle
          .replace(/&amp;/g, '&')
          .replace(/&quot;/g, '"')
          .replace(/&#39;/g, "'");
      }
      if (mediaDesc) {
        const plain = mediaDesc
          .replace(/&amp;/g, '&')
          .replace(/&lt;/g, '<')
          .replace(/&gt;/g, '>')
          .replace(/\s+/g, ' ')
          .trim();
        if (plain.length > 0) {
          youtubeLatest.description =
            plain.length > 280 ? `${plain.slice(0, 277)}…` : plain;
        }
      }
    }
  }
} catch {
  /* RSS no disponible en build (sin red, etc.) */
}

---

<Layout title="Andes Solar Hash | Minería de Bitcoin en Chile">
  <!-- TICKER BAR -->
  <div class="ticker-bar">
    <div class="ticker-item">
      <span class="ticker-label">BTC/USD</span>
      <span class="ticker-value" id="btc-price">$84,532.00</span>
    </div>
    <div class="ticker-item">
      <span class="ticker-label">24h</span>
      <span class="ticker-value ticker-up">+2.34%</span>
    </div>
    <div class="ticker-item">
      <span class="ticker-label">HASHRATE</span>
      <span class="ticker-value">612.5 EH/s</span>
    </div>
    <div class="ticker-item">
      <span class="ticker-label">DIFICULTAD</span>
      <span class="ticker-value">83.7 T</span>
    </div>
    <div class="ticker-item">
      <span class="ticker-label">PRÓXIMO HALVING</span>
      <span class="ticker-value">~120 días</span>
    </div>
  </div>

  <!-- HERO SECTION -->
  <Hero
    title="Minería de\nBitcoin con\nsoporte local en\nChile."
    subtitle="Compra equipos completos o participa de forma fraccionada en infraestructura minera profesional."
    badge="COMPAÑÍA CHILENA | GESTIÓN LEGAL (SII)"
    backgroundImage="/images/home/hero/hero_background.png"
    ctaButtons={[
      { text: 'VER EQUIPOS S21 EN STOCK', href: '#productos', variant: 'outline', icon: 'clock' },
      { text: 'COTIZAR FRACCIONAMIENTO', href: '#contacto', variant: 'solid' }
    ]}
  />

  <!-- INTRO SECTION -->
  <section class="intro">
    <h2>Minería de Bitcoin con métricas claras y<br />estructura verificable.</h2>
    <p>Andes Solar Hash desarrolla y opera infraestructura minera optimizada para eficiencia energética, estabilidad operativa y trazabilidad de resultados. Cada producto está respaldado por datos técnicos, costos transparentes y monitoreo continuo.</p>
    <p class="bold">Nuestra propuesta se adapta a distintos perfiles: compra directa de ASIC, contratos de hosting o fraccionamiento de capacidad minera, siempre bajo una operación local y controlada en Chile.</p>
  </section>

  <!-- PRODUCTS GRID -->
  <section class="products" id="productos">
    <div class="products-grid">
      {products.map((product) => (
        <ProductCard
          title={product.title}
          tag={product.tag}
          description={product.description}
          image={product.image}
          features={product.features}
          cta={product.cta}
        />
      ))}
    </div>
  </section>

  <!-- FEATURED PRODUCT: S21 XP -->
  <FeaturedProduct
    label="MINERO ASIC DESTACADO | ROI DESDE 17 MESES"
    title="Antminer S21 XP: El Costo Más\nBajo por Hash"
    description="El S21 XP es el equipo más eficiente (13.5 J/TH). Invertir aquí significa generar su Bitcoin con mayor descuento que cualquier otro modelo, maximizando el valor para el próximo ciclo alcista."
    specs={[
      'Eficiencia: 13.5 J/TH (Máximo Margen)',
      'Precio CLP: $7.999.999 (Entrega en Chile)',
      'ROI Estimado: 17–24 meses'
    ]}
    image="/images/productos/content/image_23_87.png"
    imageAlt="Antminer S21 XP"
    ctaButtons={[
      { text: 'VER DETALLE Y COMPRAR', href: '/productos/s21-xp/', variant: 'outline' },
      { text: 'COTIZAR FRACCIÓN (1%)', href: '#contacto', variant: 'solid' }
    ]}
  />

  <!-- VIDEO SECTION: embed = playlist de subidas (siempre el último video); texto desde RSS en build -->
  <section class="video-section">
    <div class="video-grid">
      <div class="video-player">
        <iframe
          src={youtubeEmbedSrc}
          title="Último video de Andes Solar Hash en YouTube"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          loading="lazy"
        />
      </div>
      <div class="video-content">
        <div class="video-label">YOUTUBE: EDUCACIÓN FINANCIERA</div>
        <h2 class="video-title">{youtubeLatest.title}</h2>
        <p class="video-desc">{youtubeLatest.description}</p>
        <a
          href={youtubeLatest.watchUrl}
          class="btn-solid"
          target="_blank"
          rel="noopener noreferrer"
        >
          VER VIDEO COMPLETO
        </a>
      </div>
    </div>
  </section>

  <!-- NEWS SECTION -->
  <section class="news-section">
    <div class="news-container">
      <div class="news-header">
        <h2>Últimas Noticias</h2>
        <a href="/blog/" class="news-link">
          VER TODO EL BLOG
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
      </div>
      <div class="news-grid">
        {newsItems.map((item) => (
          <a
            href={item.href}
            class="news-card"
            style={item.image ? undefined : { background: item.gradient }}
          >
            {item.image ? (
              <img
                class="news-card-img"
                src={item.image}
                alt=""
                loading="lazy"
                decoding="async"
              />
            ) : null}
            <span class="news-overlay" aria-hidden="true"></span>
            <span class="news-content">
              <span class="news-meta">{item.date} | {item.category}</span>
              <h3 class="news-title">{item.title}</h3>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section id="contacto" class="newsletter">
    <div class="newsletter-container">
      <h2>Reciba la Tesis de Inversión ASH.</h2>
      <p>Únase a nuestro newsletter exclusivo. Reciba análisis cíclicos y noticias de infraestructura que realmente mueven la aguja.</p>
      <form onsubmit="event.preventDefault(); alert('¡Gracias por suscribirte!');">
        <input type="email" placeholder="Su correo electrónico aquí..." required />
        <button type="submit">SUSCRIBIRME</button>
      </form>
    </div>
  </section>

  <style>
    /* TICKER BAR */
    .ticker-bar {
      background: #000;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      padding: 8px 16px;
      display: flex;
      gap: 40px;
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      letter-spacing: 1.2px;
      white-space: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .ticker-bar::-webkit-scrollbar {
      display: none;
    }
    .ticker-item {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .ticker-label {
      color: var(--gold);
    }
    .ticker-value {
      color: white;
      font-weight: 700;
    }
    .ticker-up {
      color: #22c55e;
    }
    .ticker-down {
      color: #ef4444;
    }

    /* HERO SECTION */
    .hero {
      position: relative;
      min-height: 720px;
      display: flex;
      align-items: center;
      padding: 120px 80px 80px;
      overflow: hidden;
      background: var(--bg-deep);
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: url('/images/home/hero/hero_background.png') center/cover no-repeat;
      opacity: 0.6;
    }
    .hero-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, var(--bg-mid) 25%, rgba(16,20,41,0) 65%);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(11,13,27,0.3) 0%, rgba(11,13,27,0.1) 50%, rgba(11,13,27,0.4) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 600px;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--gold);
      border-radius: 9999px;
      padding: 5px 13px;
      margin-bottom: 24px;
    }
    .hero-badge-dot {
      width: 8px;
      height: 8px;
      background: var(--gold);
      border-radius: 50%;
    }
    .hero-badge-text {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 12px;
      color: var(--gold);
      letter-spacing: 0.5px;
    }
    .hero h1 {
      font-family: 'Maven Pro', sans-serif;
      font-weight: 900;
      font-size: clamp(48px, 5vw, 72px);
      line-height: 1.05;
      background: linear-gradient(to right, var(--gold-dark), var(--gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 28px;
    }
    .hero-sub {
      font-weight: 700;
      font-size: 18px;
      line-height: 1.6;
      color: white;
      margin-bottom: 40px;
      max-width: 520px;
    }
    .hero-btns {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    /* Intro Section */
    .intro {
      text-align: center;
      padding: 96px 80px 60px;
      background: var(--bg-deep);
    }
    .intro h2 {
      font-family: 'Maven Pro', sans-serif;
      font-weight: 900;
      font-size: clamp(28px, 3vw, 36px);
      text-transform: uppercase;
      background: linear-gradient(to right, var(--gold-dark), var(--gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 24px;
      line-height: 1.15;
    }
    .intro p {
      color: var(--text-light);
      font-size: 18px;
      line-height: 1.7;
      max-width: 900px;
      margin: 0 auto 16px;
    }
    .intro p.bold {
      color: white;
      font-weight: 700;
    }

    /* Products Section */
    .products {
      padding: 40px 80px 96px;
      background: var(--bg-deep);
    }
    .cta-note {
      font-size: 13px;
      color: #ccc;
      text-align: center;
      margin-bottom: 8px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      font-weight: 700;
    }
    .cta-note-orange {
      font-size: 14px;
      color: #ccc;
      font-weight: 700;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 8px;
    }
    .btn-cta-orange {
      background: var(--gold-dark);
      color: var(--bg-deep);
      border: none;
      border-radius: 100px;
      padding: 14px 32px;
      font-family: 'Maven Pro', sans-serif;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      width: 100%;
      transition: opacity 0.2s;
      text-align: center;
      text-decoration: none;
      display: block;
    }
    .btn-cta-orange:hover {
      opacity: 0.9;
    }

    /* Featured Section */
    .featured {
      padding: 80px;
      background: linear-gradient(to right, rgba(29,34,66,0.3), transparent, rgba(29,34,66,0.3)), var(--bg-deep);
      position: relative;
      overflow: hidden;
    }
    .featured-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
      max-width: 1280px;
      margin: 0 auto;
    }
    .featured-label {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 14px;
      color: white;
      letter-spacing: 1.4px;
      text-transform: uppercase;
      margin-bottom: 18px;
    }
    .featured-title {
      font-family: 'Maven Pro', sans-serif;
      font-weight: 900;
      font-size: clamp(28px, 3vw, 36px);
      color: #f7ad1f;
      -webkit-text-fill-color: #f7ad1f;
      line-height: 1.2;
      margin-bottom: 20px;
    }
    .featured-desc {
      font-size: 18px;
      color: white;
      line-height: 1.65;
      margin-bottom: 28px;
    }
    .featured-list {
      list-style: none;
      margin-bottom: 36px;
    }
    .featured-list li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14px;
      color: var(--text-light);
      margin-bottom: 12px;
    }
    .featured-list svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }
    .featured-btns {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    .featured-image {
      display: flex;
      justify-content: center;
    }
    .featured-image img {
      width: 100%;
      max-width: 460px;
      filter: drop-shadow(0 24px 48px rgba(0,0,0,0.5));
    }

    /* Video Section */
    .video-section {
      padding: 80px;
      background: var(--bg-deep);
    }
    .video-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
      max-width: 1280px;
      margin: 0 auto;
    }
    .video-player {
      background: #111827;
      border-radius: 12px;
      aspect-ratio: 16/9;
      overflow: hidden;
      position: relative;
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
    }
    .video-player iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
    .video-label {
      font-size: 14px;
      font-weight: 700;
      color: #ef4444;
      letter-spacing: 1.4px;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .video-title {
      font-family: 'Maven Pro', sans-serif;
      font-weight: 700;
      font-size: clamp(22px, 2.5vw, 30px);
      line-height: 1.3;
      color: #f7ad1f;
      margin-bottom: 20px;
    }
    .video-desc {
      font-size: 16px;
      color: white;
      line-height: 1.65;
      margin-bottom: 28px;
    }

    /* News Section */
    .news-section {
      background: #15172e;
      padding: 80px;
    }
    .news-container {
      max-width: 1280px;
      margin: 0 auto;
    }
    .news-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 44px;
    }
    .news-header h2 {
      font-family: 'Maven Pro', sans-serif;
      font-weight: 700;
      font-size: 44px;
      color: #f7ad1f;
      -webkit-text-fill-color: #f7ad1f;
      line-height: 1;
    }
    .news-link {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      font-weight: 700;
      color: white;
      letter-spacing: 0.5px;
      text-decoration: none;
      text-transform: uppercase;
    }
    .news-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
    .news-card {
      border-radius: 12px;
      overflow: hidden;
      height: 300px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      position: relative;
      cursor: pointer;
      transition: transform 0.25s;
      text-decoration: none;
      color: inherit;
      background: #1a2040;
    }
    .news-card-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }
    .news-card:hover {
      transform: translateY(-4px);
    }
    .news-overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.88) 0%, rgba(0, 0, 0, 0.35) 45%, rgba(0, 0, 0, 0.1) 100%);
    }
    .news-content {
      position: relative;
      z-index: 2;
      padding: 24px;
    }
    .news-meta {
      font-size: 12px;
      font-weight: 700;
      color: white;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
      text-transform: uppercase;
    }
    .news-title {
      display: block;
      margin: 0;
      font-family: 'Maven Pro', sans-serif;
      font-weight: 700;
      font-size: 19px;
      line-height: 1.35;
      color: white;
    }

    /* Newsletter */
    .newsletter {
      background: var(--bg-deep);
      padding: 80px;
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .newsletter-container {
      max-width: 1100px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }
    .newsletter h2 {
      font-family: 'Maven Pro', sans-serif;
      font-weight: 900;
      font-size: clamp(22px, 2.5vw, 30px);
      text-transform: uppercase;
      color: #f7ad1f;
      -webkit-text-fill-color: #f7ad1f;
      margin-bottom: 16px;
      line-height: 1.2;
    }
    .newsletter p {
      font-size: 18px;
      color: white;
      line-height: 1.6;
      margin-bottom: 36px;
    }
    .newsletter form {
      display: flex;
      gap: 12px;
      max-width: 600px;
      margin: 0 auto;
    }
    .newsletter input {
      flex: 1;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 4px;
      padding: 18px 16px;
      font-size: 16px;
      color: white;
      font-family: 'Archivo', sans-serif;
      outline: none;
    }
    .newsletter input::placeholder {
      color: rgba(255,255,255,0.5);
    }
    .newsletter button {
      background: var(--gold);
