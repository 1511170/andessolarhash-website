---
import Layout from '../../layouts/Layout.astro';

/** Página alineada a Figma HOSTING (nodo 147:132) — https://www.figma.com/design/9Yz7rsHqdK9ITCLH9J2FdX/ANDES-SOLAR-HASH---KINTO?node-id=147-132 */

const title = 'Hosting Minero en Chile | Andes Solar Hash';
const description =
  'Hosting profesional para ASIC con tarifa eléctrica fija $0.088 USD/kWh, uptime 99.9% y soporte local en Chile.';

const imgMiner = '/images/hosting/figma/hero_miner.webp';
const imgWatermark = '/images/hosting/figma/btc_watermark.webp';

const pillars = [
  {
    title: ['Eficiencia Energética', 'Superior'],
    body: [
      'Nuestra tarifa fija y baja ($0.088 USD/kWh) le permite ',
      'maximizar el margen operativo',
      ' de sus mineros S21, asegurando que su costo de producción de Bitcoin sea el más competitivo del mercado.',
    ],
    icon: 'zap',
  },
  {
    title: ['Uptime Garantizado 99.9%'],
    body: [
      'Ofrecemos estabilidad operativa garantizada. Nuestro centro de datos está optimizado para la disipación de calor y la redundancia eléctrica, minimizando las interrupciones y el ',
      'downtime',
      ' de su hardware.',
    ],
    icon: 'shield',
  },
  {
    title: ['Gestión y Soporte en Chile'],
    body: [
      'Aseguramos la gestión legal y operativa de sus equipos desde Chile. Acceda a contratos claros y soporte técnico local, eliminando las complejidades de la logística internacional.',
    ],
    icon: 'pin',
  },
];

const contractRows = [
  { label: 'Tarifa Eléctrica Fija', value: '$0.088 USD/kWh', labelBold: true, valueMono: true },
  {
    label: 'Monitoreo Técnico',
    value: '24 Horas / 7 Días a la semana',
    icon: 'eye',
    labelMuted: true,
  },
  {
    label: 'Uptime Garantizado',
    value: '99.9% (SLA en contrato)',
    labelMuted: true,
    valueMono: true,
  },
  {
    label: 'Mantenimiento de Hardware',
    value: 'Soporte Local y Preventivo',
    icon: 'wrench',
    labelMuted: true,
  },
];
---

<Layout title={title} description={description}>
  <!-- HERO — Figma Header 147:290 -->
  <section
    class="relative border-b border-white/10 overflow-hidden pt-28 pb-16 md:pb-24"
    style="background: var(--bg-deep);"
  >
    <div class="max-w-[1280px] mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-start">
        <div class="max-w-xl">
          <p class="font-archivo font-bold text-sm text-white tracking-[0.14em] uppercase mb-4">
            Infraestructura y eficiencia
          </p>
          <h1
            class="font-maven font-black text-4xl sm:text-5xl lg:text-[3.35rem] leading-[1.05] mb-6"
            style="background: linear-gradient(to right, #e08324, #f7ad1f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
          >
            Hosting Minero con<br />
            Costo Eléctrico de<br />
            Fábrica.
          </h1>
          <p class="font-archivo text-lg md:text-xl text-[#d1d5db] leading-relaxed mb-8">
            Asegure el margen de su inversión con nuestra <strong class="text-white">tarifa fija de $0.088 USD/kWh</strong> en
            infraestructura optimizada para el largo plazo. No más costos variables, solo acumulación eficiente.
          </p>
          <a
            href="/contacto/#contacto"
            class="inline-flex items-center gap-3 bg-[#f7ad1f] text-[#0b0d1b] font-archivo font-black text-lg md:text-xl px-6 py-3.5 rounded hover:opacity-95 transition-opacity w-full sm:w-auto justify-center"
          >
            <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <path d="M16 2v4M8 2v4M3 10h18" stroke-linecap="round" />
            </svg>
            AGENDAR LLAMADA DE EVALUACIÓN
          </a>
        </div>

        <div class="relative flex flex-col items-center lg:items-end lg:pt-4">
          <div class="relative w-full max-w-md flex justify-center pb-4">
            <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-[70%] h-8 bg-black/40 blur-2xl rounded-full pointer-events-none" aria-hidden="true" />
            <img
              src={imgMiner}
              alt="Minero ASIC en hosting"
              class="relative z-10 w-[min(100%,280px)] h-auto object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.45)] -mt-2"
              loading="eager"
            />
          </div>

          <div
            class="relative z-20 w-full max-w-md mt-4 rounded-xl border-4 border-[#e08324] bg-[#0b0d1b]/80 backdrop-blur-sm shadow-2xl text-center px-6 py-8"
            style="box-shadow: 0 25px 50px -12px rgba(0,0,0,0.35);"
          >
            <p class="font-maven font-bold text-sm text-white mb-3">TARIFA ELÉCTRICA GARANTIZADA</p>
            <div class="flex flex-wrap items-end justify-center gap-2 mb-2">
              <span
                class="font-mono font-bold text-5xl sm:text-6xl lg:text-7xl leading-none"
                style="background: linear-gradient(to right, #e08324, #f7ad1f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
              >
                $0.088
              </span>
              <span class="font-archivo text-2xl sm:text-3xl text-white pb-1">USD/kWh</span>
            </div>
            <p class="font-archivo text-sm text-white/90">
              El factor decisivo para mantener la rentabilidad post-Halving.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRES PILARES — Figma 147:307 -->
  <section class="relative py-16 md:py-24 px-4 md:px-8 bg-[#15172e] overflow-hidden">
    <img
      src={imgWatermark}
      alt=""
      class="pointer-events-none absolute -right-20 top-1/2 -translate-y-1/2 w-[min(100%,812px)] opacity-[0.04] mix-blend-luminosity max-lg:hidden"
      loading="lazy"
    />
    <div class="relative z-10 max-w-[1280px] mx-auto">
      <h2 class="font-maven font-bold text-2xl md:text-[30px] text-[#f7ad1f] text-center mb-12 md:mb-16 px-2">
        Los Tres Pilares de Nuestro Servicio de Hosting
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {pillars.map((p) => (
          <article
            class="rounded-xl border border-white/10 border-t-4 border-t-[#f7ad1f] bg-[#1a1d3a] p-6 md:p-6 flex flex-col"
          >
            <div class="mb-4 text-[#f7ad1f]">
              {p.icon === 'zap' && (
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z" stroke-linejoin="round" />
                </svg>
              )}
              {p.icon === 'shield' && (
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {p.icon === 'pin' && (
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              )}
            </div>
            <h3 class="font-maven font-bold text-xl md:text-2xl text-[#f7ad1f] mb-4 leading-snug">
              {p.title.map((line, i) => (
                <>
                  {i > 0 && <br />}
                  {line}
                </>
              ))}
            </h3>
            <p class="font-archivo text-base text-white leading-relaxed flex-grow">
              {p.body.length === 1 ? (
                p.body[0]
              ) : (
                <>
                  {p.body[0]}
                  <strong>{p.body[1]}</strong>
                  {p.body[2]}
                </>
              )}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTRATO — Figma 147:327 -->
  <section class="relative py-16 md:py-24 px-4 md:px-8 overflow-hidden" style="background: var(--bg-deep);">
    <img
      src={imgWatermark}
      alt=""
      class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[min(90vw,600px)] opacity-[0.035] mix-blend-lighten"
      loading="lazy"
    />
    <div class="relative z-10 max-w-3xl mx-auto">
      <h2 class="font-maven font-bold text-2xl md:text-[30px] text-[#f7ad1f] text-center mb-10 md:mb-12">
        Detalles del Contrato de Hosting Anual
      </h2>
      <div class="space-y-0 font-archivo text-lg">
        {contractRows.map((row) => (
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 py-4 border-b border-white/10 text-white"
          >
            <div class:list={['flex items-center gap-2 flex-wrap', row.labelBold ? 'font-bold' : 'font-bold text-[#d1d5db]']}>
              {row.label}
            </div>
            <div class:list={['flex items-center gap-2 sm:text-right', row.valueMono ? 'font-mono' : 'font-normal']}>
              {row.icon === 'eye' && (
                <svg class="w-5 h-5 text-[#f7ad1f] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              )}
              {row.icon === 'wrench' && (
                <svg class="w-5 h-5 text-[#f7ad1f] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" />
                </svg>
              )}
              <span>{row.value}</span>
            </div>
          </div>
        ))}
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 pt-4">
          <span class="font-bold text-[#d1d5db]">Duración Estándar</span>
          <span class="font-archivo font-black text-xl text-white">12 Meses (Renovable)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL — Figma 147:348 -->
  <section class="py-16 md:py-24 px-4 text-center" style="background: var(--bg-deep);">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-maven font-black text-2xl sm:text-3xl md:text-4xl text-[#f7ad1f] mb-6 leading-tight">
        ¿Listo para Optimizar su Margen?
      </h2>
      <p class="font-archivo text-lg text-white mb-10 leading-relaxed">
        El hosting ASIC es una inversión de alta seriedad. Permítanos entender su escala y proponerle una solución a la
        medida.
      </p>
      <a
        href="/contacto/#contacto"
        class="inline-flex items-center justify-center gap-3 bg-[#f7ad1f] text-[#0b0d1b] font-archivo font-black text-lg md:text-2xl px-8 py-4 md:py-5 rounded w-full max-w-xl mx-auto hover:opacity-95 transition-opacity"
      >
        <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
        </svg>
        SOLICITAR COTIZACIÓN CONSULTIVA
      </a>
    </div>
  </section>
</Layout>
