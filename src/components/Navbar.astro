---
const productMenuLinks = [
  { href: '/productos/', label: 'Catálogo completo' },
  { href: '/productos/s21-xp/', label: 'Antminer S21 XP' },
  { href: '/productos/s21-pro/', label: 'Antminer S21 Pro' },
  { href: '/productos/s21-plus/', label: 'Antminer S21 +' },
  { href: '/productos/s21-plus-nft/', label: 'Antminer S21 + NFT' },
  { href: '/productos/l9-17000/', label: 'Antminer L9 17000' },
  { href: '/productos/l9-16000/', label: 'Antminer L9 16000' },
  { href: '/productos/l9-15000/', label: 'Antminer L9 15000' },
];

const navLinks = [
  { href: '/hosting/', label: 'Hosting' },
  { href: '/nft/', label: 'NFT' },
  { href: '/blog/', label: 'Blog' },
];
---

<nav>
  <a href='/' class="nav-logo" style="text-decoration:none; cursor:pointer;">
    <img src="/images/andessh_001.png" alt="Andes Solar Hash - Minería Bitcoin Chile" />
    <div>
      <div class="nav-logo-text" aria-hidden="true">ANDES SOLAR <span style="color: var(--gold)">HASH</span></div>
      <div class="nav-logo-sub" aria-hidden="true">MINERÍA BITCOIN CHILE</div>
    </div>
  </a>
  
  <ul class="nav-links">
    <li>
      <a href="/">Inicio</a>
    </li>
    <li class="nav-dropdown">
      <a href="/productos/" class="nav-dropdown-trigger">
        Productos de Minería
        <svg class="nav-dropdown-chevron" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M3 4.5L6 7.5L9 4.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <ul class="nav-dropdown-panel" role="menu">
        {productMenuLinks.map((item) => (
          <li role="none">
            <a href={item.href} role="menuitem">{item.label}</a>
          </li>
        ))}
      </ul>
    </li>
    {navLinks.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
  
  <a class="btn-contact" href='/contacto/#contacto'>CONTÁCTANOS</a>
  
  <button class="hamburger" id="hamburger" aria-label="Menú">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-inner">
    <div class="mobile-menu-section">
      <div class="mobile-menu-section-title">Sitio</div>
      <a href="/">Inicio <span class="arrow">›</span></a>
      <a href='/hosting/'>Hosting Minero Profesional <span class="arrow">›</span></a>
      <a href='/nft/'>NFTs Productivos de Minería <span class="arrow">›</span></a>
    </div>

    <div class="mobile-menu-section">
      <div class="mobile-menu-section-title">Productos de minería</div>
      {productMenuLinks.map((item) => (
        <a href={item.href}>{item.label} <span class="arrow">›</span></a>
      ))}
    </div>
    
    <div class="mobile-menu-section">
      <div class="mobile-menu-section-title">Empresa</div>
      <a href="/blog/">Blog y Noticias <span class="arrow">›</span></a>
    </div>
    
    <div class="mobile-menu-cta">
      <a href='/contacto/#contacto'>CONTÁCTANOS</a>
    </div>
  </div>
</div>

<script>
  // Mobile menu toggle
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = mobileMenu.classList.toggle('open');
      hamburger.classList.toggle('open', isOpen);
    });
    
    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('open');
      });
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (!hamburger.contains(e.target) && !mobileMenu.contains(e.target)) {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('open');
      }
    });
  }
</script>
