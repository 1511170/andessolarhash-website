---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  author: string;
  category?: string;
  slug: string;
  image?: string;
  readTime?: string;
}

const {
  title,
  excerpt,
  date,
  author,
  category = "General",
  slug,
  image,
  readTime = "5 min"
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="blog-card">
  <a href={`/blog/${slug}`} class="blog-card-link">
    <div class="blog-card-image">
      {image ? (
        <img src={image} alt={title} loading="lazy" />
      ) : (
        <div class="blog-card-placeholder">
          <span class="placeholder-icon">📝</span>
        </div>
      )}
    </div>
  </a>

  <div class="blog-card-content">
    <div class="blog-card-meta">
      {category && (
        <span class="blog-card-category">{category}</span>
      )}
      <span class="blog-card-date">{formattedDate}</span>
      <span class="blog-card-separator">•</span>
      <span class="blog-card-time">{readTime} lectura</span>
    </div>

    <h3 class="blog-card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>

    <p class="blog-card-excerpt">{excerpt}</p>

    <div class="blog-card-author">
      <div class="author-avatar">
        {author.split(' ').map(n => n[0]).join('')}
      </div>
      <span class="author-name">{author}</span>
    </div>
  </div>
</article>

<style>
  .blog-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.05);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    border-color: rgba(247, 173, 31, 0.3);
  }

  .blog-card-link {
    display: block;
    text-decoration: none;
  }

  .blog-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-bg-mid) 0%, var(--color-bg-deep) 100%);
    position: relative;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.05);
  }

  .blog-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-icon {
    font-size: 4rem;
    opacity: 0.3;
  }

  .blog-card-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .blog-card-category {
    background: rgba(247, 173, 31, 0.15);
    color: var(--color-gold);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .blog-card-date,
  .blog-card-time {
    color: var(--color-text-muted);
  }

  .blog-card-separator {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .blog-card-title {
    font-family: var(--font-family-display);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .blog-card-title a {
    color: white;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .blog-card-title a:hover {
    color: var(--color-gold);
  }

  .blog-card-excerpt {
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .author-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gold) 0%, var(--color-gold-dark) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-bg-deep);
  }

  .author-name {
    color: var(--color-text-light);
    font-size: 0.875rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .blog-card-title {
      font-size: 1.25rem;
    }

    .blog-card-content {
      padding: 1.25rem;
    }
  }
</style>
