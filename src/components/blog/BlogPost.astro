---
interface Props {
  title: string;
  content: string;
  excerpt: string;
  date: Date;
  author: string;
  authorRole?: string;
  category?: string;
}

const {
  title,
  content,
  excerpt,
  date,
  author,
  authorRole = "",
  category = "General"
} = Astro.props;

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="blog-post">
  <!-- Header -->
  <header class="post-header">
    <div class="post-meta">
      {category && (
        <span class="post-category">
          {category}
        </span>
      )}
      <span class="post-date">{formattedDate}</span>
    </div>

    <h1 class="post-title">{title}</h1>

    <p class="post-excerpt">{excerpt}</p>
  </header>

  <!-- Author -->
  <div class="post-author">
    <div class="author-avatar">
      {author.split(' ').map(n => n[0]).join('')}
    </div>
    <div class="author-info">
      <div class="author-name">{author}</div>
      {authorRole && <div class="author-role">{authorRole}</div>}
    </div>
  </div>

  <!-- Content -->
  <div class="post-content">
    <slot />
  </div>

  <!-- Share -->
  <div class="post-share">
    <p class="share-label">Compartir artículo:</p>
    <div class="share-buttons">
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}`}
        target="_blank"
        rel="noopener"
        class="share-btn"
        aria-label="Compartir en Twitter"
      >
        <span>𝕏</span>
      </a>
      <a
        href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(typeof window !== 'undefined' ? window.location.href : '')}`}
        target="_blank"
        rel="noopener"
        class="share-btn"
        aria-label="Compartir en LinkedIn"
      >
        <span>in</span>
      </a>
      <button
        onclick="navigator.clipboard.writeText(window.location.href)"
        class="share-btn"
        title="Copiar enlace"
        aria-label="Copiar enlace"
      >
        <span>🔗</span>
      </button>
    </div>
  </div>
</article>

<style>
  .blog-post {
    max-width: 800px;
    margin: 0 auto;
    color: var(--color-text-light);
  }

  /* Header */
  .post-header {
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .post-category {
    background: rgba(247, 173, 31, 0.15);
    color: var(--color-gold);
    padding: 0.5rem 1rem;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .post-title {
    font-family: var(--font-family-display);
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1.2;
    color: white;
    margin-bottom: 1rem;
  }

  .post-excerpt {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-text-light);
  }

  /* Author */
  .post-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .author-avatar {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gold) 0%, var(--color-gold-dark) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-bg-deep);
  }

  .author-name {
    font-weight: 600;
    color: white;
    font-size: 1rem;
  }

  .author-role {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  /* Content */
  .post-content {
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-family: var(--font-family-display);
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .post-content :global(h3) {
    font-family: var(--font-family-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(h4) {
    font-family: var(--font-family-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(a) {
    color: var(--color-gold);
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .post-content :global(a:hover) {
    color: var(--color-gold-dark);
  }

  .post-content :global(strong) {
    color: white;
    font-weight: 600;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(code) {
    background-color: var(--color-bg-card);
    color: var(--color-gold-light);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'Courier New', monospace;
  }

  .post-content :global(pre) {
    background-color: var(--color-bg-card);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text-light);
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-gold);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-text-light);
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    display: block;
  }

  .post-content :global(th),
  .post-content :global(td) {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.75rem;
    text-align: left;
  }

  .post-content :global(th) {
    background-color: var(--color-bg-card);
    color: white;
    font-weight: 600;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2rem 0;
  }

  /* Share */
  .post-share {
    padding-top: 2rem;
    margin-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .share-label {
    color: var(--color-text-light);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .share-buttons {
    display: flex;
    gap: 0.75rem;
  }

  .share-btn {
    width: 2.5rem;
    height: 2.5rem;
    background-color: var(--color-bg-card);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light);
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    font-size: 1rem;
  }

  .share-btn:hover {
    background-color: rgba(247, 173, 31, 0.2);
    border-color: var(--color-gold);
    color: var(--color-gold);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 2rem;
    }

    .post-excerpt {
      font-size: 1.125rem;
    }

    .post-content {
      font-size: 1rem;
    }

    .post-content :global(h2) {
      font-size: 1.75rem;
    }

    .post-content :global(h3) {
      font-size: 1.375rem;
    }
  }
</style>
