---
import siteConfig from '../../config/site.config.ts';

const contactEmail = siteConfig.site?.contactEmail || 'soporte@andessolarhash.com';

const quickLinks = [
  { href: '/productos/', label: 'Venta de ASICs (S21)' },
  { href: '/hosting/', label: 'Hosting Sustentable' },
  { href: '/nft/', label: 'Fraccionamiento (1%)' },
];

const legalLinks = [
  { href: '/legal/privacidad/', label: 'Política de Privacidad' },
  { href: '/legal/cookies/', label: 'Cookies' },
  { href: '/legal/terminos-nft/', label: 'Términos y Condiciones NFTs' },
  { href: '/legal/riesgo/', label: 'Aviso Legal y de Riesgos' },
];

const socialLinks = [
  {
    href: 'https://youtube.com/@andessolarhash?si=L9ujSqc3iJ70P0MQ',
    label: 'YouTube',
    title: 'YouTube',
    icon: 'youtube',
  },
  {
    href: 'https://www.linkedin.com/in/andes-solarhash-201049397?utm_source=share_via&utm_content=profile&utm_medium=member_ios',
    label: 'LinkedIn',
    title: 'LinkedIn',
    icon: 'linkedin',
  },
  {
    href: 'https://x.com/andessolarhash?s=21',
    label: 'Twitter / X',
    title: 'Twitter / X',
    icon: 'x',
  },
  {
    href: 'https://www.instagram.com/andessolarhash?igsh=a29mamRvbnl5bzdx',
    label: 'Instagram',
    title: 'Instagram',
    icon: 'instagram',
  },
  {
    href: 'https://www.tiktok.com/@andessolarhash?_r=1&_t=ZS-94ZernUIRsa',
    label: 'TikTok',
    title: 'TikTok',
    icon: 'tiktok',
  },
];
---

<footer id="contacto">
  <div class="footer-inner">
    <div class="footer-brand">
      <img
        src="/images/brand-footer-logo.webp"
        alt="Andes Solar Hash"
        loading="lazy"
        decoding="async"
      />
      <p>Compañía chilena enfocada en infraestructura real. No somos brokers, somos productores.</p>
      <div class="footer-social">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            title={social.title}
          >
            {social.icon === 'youtube' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z" />
              </svg>
            )}
            {social.icon === 'linkedin' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.4 20.4h-3.6v-5.6c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9v5.7H9.3V9h3.4v1.6h.1c.5-.9 1.6-1.8 3.3-1.8 3.5 0 4.2 2.3 4.2 5.4v6.2zM5.3 7.4a2.1 2.1 0 1 1 0-4.2 2.1 2.1 0 0 1 0 4.2zM7.1 20.4H3.5V9h3.6v11.4zM22.2 0H1.8C.8 0 0 .8 0 1.7v20.6C0 23.2.8 24 1.8 24h20.4c1 0 1.8-.8 1.8-1.7V1.7C24 .8 23.2 0 22.2 0z" />
              </svg>
            )}
            {social.icon === 'x' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.2 2h3.4l-7.4 8.5L23 22h-6.8l-5.3-7-6.1 7H1.4l7.9-9L1 2h7l4.8 6.4L18.2 2zm-1.2 18h1.9L7.1 4H5.1l11.9 16z" />
              </svg>
            )}
            {social.icon === 'instagram' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.2c3.2 0 3.6 0 4.9.1 3.3.1 4.8 1.7 4.9 4.9.1 1.3.1 1.6.1 4.8 0 3.2 0 3.6-.1 4.8-.1 3.2-1.7 4.8-4.9 4.9-1.3.1-1.6.1-4.9.1-3.2 0-3.6 0-4.8-.1-3.3-.1-4.8-1.7-4.9-4.9C2.2 15.6 2.2 15.2 2.2 12c0-3.2 0-3.6.1-4.8C2.4 3.9 4 2.3 7.2 2.3 8.4 2.2 8.8 2.2 12 2.2zM12 0C8.7 0 8.3 0 7.1.1 2.7.3.3 2.7.1 7.1 0 8.3 0 8.7 0 12c0 3.3 0 3.7.1 4.9.2 4.4 2.6 6.8 7 7C8.3 24 8.7 24 12 24c3.3 0 3.7 0 4.9-.1 4.4-.2 6.8-2.6 7-7 .1-1.2.1-1.6.1-4.9 0-3.3 0-3.7-.1-4.9C23.7 2.7 21.3.3 16.9.1 15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4A6.2 6.2 0 0 0 12 5.8zm0 10.2a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.8a1.4 1.4 0 1 0 0 2.8 1.4 1.4 0 0 0 0-2.8z" />
              </svg>
            )}
            {social.icon === 'tiktok' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.6 5a5.3 5.3 0 0 1-3.2-1.1A5.3 5.3 0 0 1 14.5 0h-3.8v16.5a2.6 2.6 0 0 1-2.6 2.3 2.6 2.6 0 0 1-2.6-2.6 2.6 2.6 0 0 1 2.6-2.6c.3 0 .5 0 .8.1V9.8a6.4 6.4 0 0 0-.8 0 6.4 6.4 0 0 0-6.4 6.4A6.4 6.4 0 0 0 8.1 22.6a6.4 6.4 0 0 0 6.4-6.4V8.1a9 9 0 0 0 5.1 1.6V6A5.3 5.3 0 0 1 19.6 5z" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <div class="footer-col">
      <h4>Productos Rápidos</h4>
      <ul>
        {quickLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Empresa y Legal</h4>
      <ul>
        {legalLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contacto</h4>
      <ul style="list-style:none; padding:0; margin:0;">
        <li style="display:flex; align-items:flex-start; gap:8px; margin-bottom:12px;">
          <svg style="flex-shrink:0; margin-top:3px;" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>Manquehue Norte 151, Oficina 1205, Las Condes, Santiago, Chile</span>
        </li>
        <li style="display:flex; align-items:center; gap:8px;">
          <svg style="flex-shrink:0;" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
          <span>{contactEmail}</span>
        </li>
      </ul>
    </div>
  </div>
</footer>
