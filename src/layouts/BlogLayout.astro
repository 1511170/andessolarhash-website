---
import Layout from './Layout.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  image?: string;
  ogImage?: string;
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
  slug?: string;
  category?: string;
  tags?: string[];
  readingTime?: number;
}

const { 
  title, 
  description, 
  image, 
  ogImage,
  publishDate = new Date(),
  modifiedDate = new Date(),
  author = "Andes Solar Hash",
  slug = "",
  category = "",
  tags = [],
  readingTime = 8
} = Astro.props;

const siteUrl = "https://andessolarhash.com";
const canonicalUrl = `${siteUrl}/blog/${slug}`;
const articleImage = ogImage || image || `${siteUrl}/images/og-default.webp`;

// Generate Article Schema (BlogPosting)
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": [
    articleImage,
    image
  ].filter(Boolean),
  "datePublished": publishDate.toISOString(),
  "dateModified": modifiedDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": author,
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "Andes Solar Hash",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/images/andessh_001.webp`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "keywords": tags.join(", "),
  "articleSection": category,
  "inLanguage": "es-CL"
};

// Generate Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${siteUrl}/blog`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": canonicalUrl
    }
  ]
};

// Generate Organization Schema
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Andes Solar Hash",
  "alternateName": "ASH",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/images/andessh_001.webp`
  },
  "description": "Minería de Bitcoin en Chile con soporte local. Venta de ASICs, hosting y NFTs productivos.",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "CL"
  },
  "sameAs": [
    "https://www.instagram.com/andessolarhash",
    "https://www.linkedin.com/company/andessolarhash"
  ]
};

// Combine all schemas
const schemas = [articleSchema, breadcrumbSchema, organizationSchema];
---

<Layout title={title} description={description}>
  <!-- Slot for additional head content -->
  <slot name="head" />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalUrl} slot="head" />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="article" slot="head" />
  <meta property="og:url" content={canonicalUrl} slot="head" />
  <meta property="og:title" content={title} slot="head" />
  <meta property="og:description" content={description} slot="head" />
  <meta property="og:image" content={articleImage} slot="head" />
  <meta property="og:site_name" content="Andes Solar Hash" slot="head" />
  <meta property="og:locale" content="es_CL" slot="head" />
  <meta property="article:published_time" content={publishDate.toISOString()} slot="head" />
  <meta property="article:modified_time" content={modifiedDate.toISOString()} slot="head" />
  <meta property="article:author" content={author} slot="head" />
  <meta property="article:section" content={category} slot="head" />
  {tags.map(tag => (
    <meta property="article:tag" content={tag} slot="head" />
  ))}
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" slot="head" />
  <meta name="twitter:url" content={canonicalUrl} slot="head" />
  <meta name="twitter:title" content={title} slot="head" />
  <meta name="twitter:description" content={description} slot="head" />
  <meta name="twitter:image" content={articleImage} slot="head" />
  
  <!-- JSON-LD Schemas -->
  {schemas.map((schema, index) => (
    <script 
      type="application/ld+json" 
      set:html={JSON.stringify(schema)}
      slot="head"
    />
  ))}
  
  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-1 bg-[#FFB800] z-50 transition-all duration-200" style="width: 0%"></div>
  
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="bg-[#1E1A1D] py-4">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-400">
        <li>
          <a href="/" class="hover:text-[#FFB800] transition-colors">Inicio</a>
        </li>
        <li>
          <span class="text-gray-600">/</span>
        </li>
        <li>
          <a href="/blog" class="hover:text-[#FFB800] transition-colors">Blog</a>
        </li>
        <li>
          <span class="text-gray-600">/</span>
        </li>
        <li>
          <span class="text-gray-300" aria-current="page">{title}</span>
        </li>
      </ol>
    </div>
  </nav>
  
  <!-- Main Content -->
  <article class="min-h-screen bg-[#1E1A1D]" itemscope itemtype="https://schema.org/BlogPosting">
    <meta itemprop="headline" content={title} />
    <meta itemprop="description" content={description} />
    <meta itemprop="datePublished" content={publishDate.toISOString()} />
    <meta itemprop="dateModified" content={modifiedDate.toISOString()} />
    
    <slot />
    
    <!-- Article Footer -->
    <footer class="container mx-auto px-6 py-12 border-t border-gray-800">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div class="text-gray-400 text-sm">
          <span>Publicado: <time itemprop="datePublished" datetime={publishDate.toISOString()}>{publishDate.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
          {modifiedDate.getTime() !== publishDate.getTime() && (
            <span class="ml-4">Actualizado: <time itemprop="dateModified" datetime={modifiedDate.toISOString()}>{modifiedDate.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
          )}
          <span class="ml-4">{readingTime} min lectura</span>
        </div>
        
        <!-- Share Buttons -->
        <div class="flex items-center space-x-4">
          <span class="text-gray-400 text-sm">Compartir:</span>
          <a 
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-[#FFB800] transition-colors"
            aria-label="Compartir en Twitter"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a 
            href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(canonicalUrl)}&title=${encodeURIComponent(title)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-[#FFB800] transition-colors"
            aria-label="Compartir en LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a 
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-[#FFB800] transition-colors"
            aria-label="Compartir en Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </article>
  
  <!-- Reading Progress Script -->
  <script>
    const progressBar = document.getElementById('reading-progress');
    
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      progressBar.style.width = scrolled + '%';
    });
  </script>
</Layout>
